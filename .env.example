# Versão do agente (filtra logs por iteração — não esquecer de bumpar a cada mudança relevante)
MODEL_VERSION=v1.9.0

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Trading
SYMBOL=EURUSD
YF_SYMBOL=EURUSD=X

# Análise — intervalo (s) entre rodadas quando NÃO há posições abertas (flat).
# Com posições, a cadência vira dinâmica: min(cadence_s) entre os horizontes
# ativos (scalp=90s, intraday=180s, swing=600s — definidos em config.HORIZON_PROFILES).
ANALYSIS_INTERVAL=300
# Quanto tempo (s) o sinal fica válido para o EA executar
SIGNAL_TTL=300

# Multi-position (v1.7) — teto de posições simultâneas. Regra adicional:
# UMA posição por (lado, horizonte). Não dobra aposta no mesmo setup.
# ATENÇÃO: risco máximo agregado = MAX_POSITIONS × RISK_PER_TRADE_PCT.
MAX_POSITIONS=3

# Risk
MIN_CONFIDENCE=0.6

# Position sizing dinâmico — risco-alvo por trade como % do equity.
# Lote final = (equity × risco% × confiança) / (pip_value × distância_SL_pips)
RISK_PER_TRADE_PCT=1.0
PIP_VALUE_PER_LOT=10.0       # USD/pip por 1 lote (EURUSD em conta USD ≈ 10)
MIN_LOT=0.01
MAX_LOT=1.0
LOT_STEP=0.01
ACCOUNT_EQUITY_FALLBACK=10000.0   # usado quando MT5 não fornece equity

# Circuit breaker — bloqueia novas aberturas (CLOSE/TIGHTEN_STOP nunca bloqueiam).
# Limites avaliados sobre trades fechados HOJE (UTC); reseta na virada do dia.
DAILY_DRAWDOWN_PCT=2.0       # % do equity que pode perder no dia
MAX_CONSECUTIVE_LOSSES=3

# TIGHTEN_STOP guardrails (v1.8.1) — evitam aperto prematuro de SL.
# MIN_TIGHTEN_PROGRESS: trade precisa estar pelo menos X% do caminho ao TP
#                      pra permitir aperto. Default 0.5 = 50%.
# MIN_TRAIL_BUFFER: novo SL deve deixar pelo menos Y% do lucro acumulado
#                  como margem (não cola no preço). Default 0.3 = 30%.
MIN_TIGHTEN_PROGRESS=0.5
MIN_TRAIL_BUFFER=0.3

# SL/TP, time exit e cadência são per-horizonte e definidos em
# config.HORIZON_PROFILES (não expostos no .env por enquanto).
# Edite lá se quiser tunar. Defaults:
#   scalp:    SL=1.0σ, TP=1.5σ, max_age=4h,   cadence=90s
#   intraday: SL=1.5σ, TP=2.5σ, max_age=24h,  cadence=180s
#   swing:    SL=2.5σ, TP=5.0σ, max_age=336h, cadence=600s

# Estimador de volatilidade para SL/TP: garch | har_rv | atr
VOL_ESTIMATOR=garch
# Tamanho do pip em unidades de preço (EURUSD=0.0001 | USDJPY=0.01)
PIP_SIZE=0.0001

# Fonte de dados: mt5 | yfinance
# mt5 usa dados diretamente do broker (mais histórico, sem gap de preço)
# yfinance é o fallback quando MT5 não está disponível
DATA_SOURCE=yfinance

# MT5 bridge (Linux/Wine) — usado quando DATA_SOURCE=mt5
# Iniciar bridge antes do agente: wine python -m mt5linux 127.0.0.1 18812
MT5_HOST=localhost
MT5_PORT=18812
